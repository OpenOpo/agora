{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "question_count", "questions_url", "scope"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "opposition": {"type": "string"},
    "level": {"type": "string"},
    "question_count": {"type": "integer", "minimum": 1},
    "scope": {
      "type": "object",
      "required": ["type", "refs"],
      "properties": {
        "type": {"enum": ["opposition", "syllabus_node", "legal_source", "legal_article", "mixed"]},
        "refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    },
    "compatible_syllabi": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "questions_url": {"type": "string", "format": "uri"},
    "github_url": {"type": "string", "format": "uri"},
    "issues_url": {"type": "string", "format": "uri"},
    "status": {"enum": ["available", "draft", "archived"]}
  }
}
