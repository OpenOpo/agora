{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "id", "title", "blocks"],
  "properties": {
    "schema_version": {"type": "integer"},
    "id": {"type": "string"},
    "title": {"type": "string"},
    "kind": {"type": "string"},
    "status": {"enum": ["available", "draft", "archived"]},
    "opposition": {"type": "string"},
    "level": {"type": "string"},
    "call": {"type": "string"},
    "source": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "url": {"type": "string", "format": "uri"},
        "extraction_note": {"type": "string"}
      }
    },
    "blocks": {
      "type": "array",
      "items": {"$ref": "#/$defs/node"}
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "id": {"type": "string"},
        "number": {"type": "integer"},
        "title": {"type": "string"},
        "refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "items": {
          "type": "array",
          "items": {"$ref": "#/$defs/node"}
        }
      },
      "anyOf": [
        {"required": ["id"]},
        {"required": ["number"]}
      ]
    }
  }
}
